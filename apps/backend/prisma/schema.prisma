// Provaliant Sales Pipeline Database Schema
// Database: SQLite (dev) -> PostgreSQL/MySQL (production)
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MASTER DATA - RBAC & USER MANAGEMENT
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // Admin, Corporate, Manager, User
  description String?
  scopeLevel  String   @default("own") // all, division, own
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // users, companies, deals, jobs, dashboard, etc
  action      String   // create, read, update, delete, approve, export
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Division {
  id               String   @id @default(uuid())
  name             String   @unique
  code             String   @unique
  colorTag         String?  // Hex color for dashboard charts
  parentDivisionId String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentDivision Division?  @relation("DivisionHierarchy", fields: [parentDivisionId], references: [id])
  subDivisions   Division[] @relation("DivisionHierarchy")

  users    User[]
  deals    Deal[]
  jobs     Job[]
  activities Activity[]
  targets  Target[]

  @@map("divisions")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  divisionId   String
  jobTitle     String?
  roleId       String
  managerId    String?
  avatarUrl    String?
  status       String   @default("active") // active, inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  division Division @relation(fields: [divisionId], references: [id])
  role     Role     @relation(fields: [roleId], references: [id])
  manager  User?    @relation("UserHierarchy", fields: [managerId], references: [id])

  subordinates User[] @relation("UserHierarchy")

  dealsOwned     Deal[]     @relation("DealOwner")
  jobsOwned      Job[]      @relation("JobOwner")
  activitiesDone Activity[] @relation("ActivityOwner")
  auditLogs      AuditLog[]
  stageChanges   DealStageHistory[]

  @@map("users")
}

// ============================================
// MASTER DATA - BUSINESS ENTITIES
// ============================================

model Industry {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  companies Company[]

  @@map("industries")
}

model Company {
  id              String   @id @default(uuid())
  name            String   @unique
  industryId      String
  channelType     String   @default("Direct") // Direct, Agency, In-Direct
  parentAgencyId  String?
  website         String?
  address         String?
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  industry     Industry  @relation(fields: [industryId], references: [id])
  parentAgency Company?  @relation("AgencyRelation", fields: [parentAgencyId], references: [id])
  subClients   Company[] @relation("AgencyRelation")

  contacts   Contact[]
  deals      Deal[]
  jobs       Job[]
  activities Activity[]

  @@map("companies")
}

model Contact {
  id         String   @id @default(uuid())
  companyId  String
  fullName   String
  jobTitle   String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  activities Activity[]

  @@map("contacts")
}

model PipelineStage {
  id        String   @id @default(uuid())
  name      String   @unique // Lead, Qualified, Discovery, Proposal, Negotiation, Won, Lost
  sortOrder Int      @unique
  isWon     Boolean  @default(false)
  isLost    Boolean  @default(false)
  createdAt DateTime @default(now())

  deals Deal[]
  stageHistories DealStageHistory[] @relation("ToStage")
  stageHistoriesFrom DealStageHistory[] @relation("FromStage")

  @@map("pipeline_stages")
}

model DealType {
  id          String   @id @default(uuid())
  name        String   @unique // IP Licensing/Sponsorship, Job/Project
  description String?
  createdAt   DateTime @default(now())

  deals Deal[]

  @@map("deal_types")
}

model JobCategory {
  id        String   @id @default(uuid())
  name      String   @unique // Operational & Production, Operational, Production, Video Production
  createdAt DateTime @default(now())

  jobs Job[]

  @@map("job_categories")
}

// ============================================
// SALES FUNNEL - ACTIVITIES & DEALS
// ============================================

model Activity {
  id              String   @id @default(uuid())
  companyId       String
  contactId       String?
  dealId          String?
  divisionId      String
  salesRepId      String
  activityDate    DateTime
  medium          String   // Offline Meeting, Online Meeting, WA, Call, Email
  objective       String
  resultNotes     String?
  nextAction      String?
  nextActionDate  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  contact  Contact? @relation(fields: [contactId], references: [id])
  deal     Deal?    @relation(fields: [dealId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])
  salesRep User     @relation("ActivityOwner", fields: [salesRepId], references: [id])

  @@map("activities")
}

model Deal {
  id                   String    @id @default(uuid())
  dealName             String
  companyId            String
  divisionId           String
  salesRepId           String
  dealTypeId           String
  stageId              String
  estimatedValue       BigInt       // Rupiah, integer to avoid floating point issues
  probabilityPct       Int       @default(0) // 0-100
  expectedClosingDate  DateTime?
  actualClosingDate    DateTime?
  lostReason           String?
  remarks              String?
  
  // IP Licensing/Sponsorship specific fields
  ipAssetName          String?
  royaltyPct           Float?
  minimumGuarantee     BigInt?
  
  // Job/Project specific fields
  jobCategoryId        String?
  billingType          String?   // Direct, Agency
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  stageChangedAt       DateTime  @default(now())

  company    Company       @relation(fields: [companyId], references: [id])
  division   Division      @relation(fields: [divisionId], references: [id])
  salesRep   User          @relation("DealOwner", fields: [salesRepId], references: [id])
  dealType   DealType      @relation(fields: [dealTypeId], references: [id])
  stage      PipelineStage @relation(fields: [stageId], references: [id])

  activities      Activity[]
  stageHistory    DealStageHistory[]
  jobs            Job[]

  @@map("deals")
}

model DealStageHistory {
  id           String   @id @default(uuid())
  dealId       String
  fromStageId  String?
  toStageId    String
  changedBy    String
  note         String?
  changedAt    DateTime @default(now())

  deal      Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage PipelineStage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   PipelineStage @relation("ToStage", fields: [toStageId], references: [id])
  user      User          @relation(fields: [changedBy], references: [id])

  @@map("deal_stage_history")
}

// ============================================
// PROJECT EXECUTION & P&L TRACKING
// ============================================

model Job {
  id                 String   @id @default(uuid())
  dealId             String?
  companyId          String
  divisionId         String
  jobTitle           String
  jobCategoryId      String
  periodMonth        Int      // 1-12
  periodYear         Int
  salesAmount        BigInt      // Rupiah
  cogsAmount         BigInt      // Cost of Goods Sold
  billingType        String   // Direct, Agency
  jobStatus          String   @default("Planning") // Planning, Ongoing, Completed, Cancelled
  picId              String
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  deal        Deal?        @relation(fields: [dealId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id])
  division    Division     @relation(fields: [divisionId], references: [id])
  jobCategory JobCategory  @relation(fields: [jobCategoryId], references: [id])
  pic         User         @relation("JobOwner", fields: [picId], references: [id])

  @@map("jobs")
}

// ============================================
// TARGETS & GOALS
// ============================================

model Target {
  id            String   @id @default(uuid())
  divisionId    String
  periodMonth   Int?     // null = yearly target
  periodYear    Int
  targetRevenue BigInt      // Rupiah
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  division Division @relation(fields: [divisionId], references: [id])

  @@unique([divisionId, periodMonth, periodYear])
  @@map("targets")
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // create, update, delete, approve, etc
  resource   String   // deals, jobs, users, etc
  resourceId String
  changes    String?  // JSON string of changes
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
